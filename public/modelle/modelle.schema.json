{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "type": {
      "const": "FeatureCollection"
    },
    "name": {
      "type": "string"
    },
    "features": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": {
            "const": "Feature"
          },
          "geometry": {
            "type": "object",
            "properties": {
              "type": {
                "const": "Point"
              },
              "coordinates": {
                "type": "array",
                "items": [
                  {
                    "type": "number",
                    "minimum": -180,
                    "maximum": 180
                  },
                  {
                    "type": "number",
                    "minimum": -90,
                    "maximum": 90
                  }
                ],
                "minItems": 2,
                "maxItems": 2
              }
            },
            "required": [
              "type",
              "coordinates"
            ],
            "additionalProperties": false
          },
          "properties": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "path": {
                "type": "string"
              },
              "rotation": {
                "type": "number",
                "minimum": 0,
                "maximum": 360
              },
              "breite": {
                "type": "number"
              },
              "tiefe": {
                "type": "number"
              },
              "hoehe": {
                "type": "number"
              },
              "id": {
                "type": "string"
              }
            },
            "required": [
              "name",
              "path",
              "rotation",
              "id"
            ],
            "additionalProperties": true
          }
        },
        "required": [
          "type",
          "geometry",
          "properties"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "type",
    "features"
  ],
  "additionalProperties": false
}